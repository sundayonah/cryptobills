// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  walletAddress String    @unique
  privyUserId   String?   @unique
  email         String?
  loginProvider String? // 'email', 'metamask', 'phantom', etc.
  walletType    String? // 'embedded', 'external', 'smart_wallet'
  loginCount    Int       @default(0)
  firstLoginAt  DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions Transaction[]

  @@index([loginProvider])
  @@index([email])
  @@index([lastLoginAt])
}

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Payment details
  walletAddress String
  token         String // 'USDC' | 'USDT'
  tokenAmount   String // Amount in token (e.g., "1.0")
  ngnAmount     Float
  exchangeRate  Float
  paymentTxHash String?

  // Network/Blockchain details
  networkChainId Int? // Chain ID (1, 137, 42161, 8453, etc.)
  networkName    String? // 'Ethereum', 'Polygon', 'Arbitrum', 'Base', etc.

  // Service/Category details
  category    String // 'airtime', 'data_bundle', 'cable_tv', 'electricity', 'showmax', 'gaming'
  service     String // Provider/service code (e.g., 'mtn_vtu', 'glo_vtu', etc.)
  serviceName String? // Human-readable service name (e.g., 'MTN VTU', 'GLO VTU')
  bundleCode  String? // Bundle code for data bundle (e.g., 'MTN_100_MB_DAILY_DATA_BUNDLE')

  // Recipient details (varies by category)
  phoneNumber   String? // For airtime, data bundle
  accountNumber String? // For cable tv, electricity
  meterNumber   String? // For electricity
  meterType     String? // For electricity: 'prepaid' | 'postpaid'
  decoderNumber String? // For cable tv

  // Customer details (for electricity, cable tv)
  customerName    String?
  customerAddress String?

  // Amount details
  serviceAmount Int // Amount sent for the service (in NGN or units)
  chargedAmount Float? // Actual amount charged (may differ from serviceAmount due to commission)
  commission    Float? // Commission charged

  // Electricity-specific fields
  electricityToken String? // Electricity token (for prepaid meters)
  electricityUnit  String? // Units purchased
  bonusToken       String? // Bonus token if any
  biller           String? // Biller name (e.g., "Ikeja Electricity - IKEDC")
  customerId       String? // Customer ID from PayBeta

  // PayBeta integration
  paybetaReference     String @unique
  paybetaTransactionId String?

  // Status tracking
  status       String // 'pending_payment' | 'payment_received' | 'converting' | 'processing' | 'completed' | 'failed'
  errorMessage String?

  // Timestamps
  createdAt         DateTime  @default(now())
  paymentReceivedAt DateTime?
  completedAt       DateTime?

  @@index([userId])
  @@index([walletAddress])
  @@index([category])
  @@index([paybetaReference])
  @@index([status])
  @@index([createdAt])
  @@index([networkChainId])
}
